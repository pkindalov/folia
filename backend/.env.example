# Copy to .env for local (non-Docker) development
PORT=1337
DB_URL=mongodb://localhost:27017/folia
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Admin account. Password is required to seed an admin (min 8 chars);
# if unset, no admin is created. To set/reset later: npm run set-admin-password
# Username and email are optional — defaults shown below.
ADMIN_PASSWORD=
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@folia.local
UPLOADS_DIR=uploads
