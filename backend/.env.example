# Copy to .env for local (non-Docker) development
PORT=1337
DB_URL=mongodb://localhost:27017/folia
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Required to have an Admin account: pick your own password (min 8 chars).
# If unset, no admin is seeded. To set/reset later: npm run set-admin-password
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@folia.local
UPLOADS_DIR=uploads
