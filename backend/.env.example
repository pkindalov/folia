# Copy to .env for local (non-Docker) development
PORT=1337
DB_URL=mongodb://localhost:27017/folia
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Optional: if unset, a random admin password is generated and printed once in the logs
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@folia.local
UPLOADS_DIR=uploads
